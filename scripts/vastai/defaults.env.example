# Copy to scripts/vastai/defaults.local.env on the remote box.
# This file is safe to keep tracked; the .local variant is ignored.

# Common model paths
# MODEL_PATH=models/llava-v1.5-13b
# QWEN_MODEL_PATH=models/Qwen-VL-Chat
# LLAVA_MODEL_PATH=models/llava-v1.5-13b

# Stage 2 / Stage 3 image resolution
# IMAGE_ROOT=$(pwd)

# Stage 3 backend defaults
# BACKEND=qwen_llava_ensemble
# LLAVA_CONV_MODE=vicuna_v1
# QWEN_MAX_NEW_TOKENS=256
# LLAVA_MAX_NEW_TOKENS=256

# Stage 4 defaults for the current GPU box
# NUM_GPUS=1
# BATCH_SIZE=1
# EPOCH=1
# OUTPUT_DIR=output/fghd/stage4_pilot

# Optional Python override for bootstrap on unusual templates
# PYTHON_BIN=python3
