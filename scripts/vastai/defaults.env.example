# Copy to scripts/vastai/defaults.local.env on the remote box.
# This file is safe to keep tracked; the .local variant is ignored.

# Common model paths
# MODEL_PATH=models/llava-v1.5-13b
# LLAVA_MODEL_PATH=models/llava-v1.5-13b

# Stage 2 / Stage 3 image resolution
# IMAGE_ROOT=$(pwd)

# Stage 3 backend defaults
# BACKEND=gemini_openai_two_vote
# BACKEND=gemini_two_vote
# BACKEND=gemini_llava_two_vote
# GEMINI_API_KEY=put_key_in_defaults.local.env_only
# OPENAI_API_KEY=put_key_in_defaults.local.env_only
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MAX_OUTPUT_TOKENS=128  # Optional cap; omit for provider default.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_OUTPUT_TOKENS=128  # Optional cap; omit for provider default.
# ROW_WORKERS=4
# LLAVA_DEVICE=cuda:0
# LLAVA_CONV_MODE=vicuna_v1
# LLAVA_MAX_NEW_TOKENS=128
# RESUME=1
# CHECKPOINT_EVERY=50

# Stage 5 paper-fair training defaults for a 1-GPU Vast box.
# These keep the HSA-DPO paper total batch size of 32 through accumulation.
# NUM_GPUS=1
# BATCH_SIZE=1
# TOTAL_BATCH_SIZE=32
# EPOCH=2
# LEARNING_RATE=2e-6
# OUTPUT_DIR=output/fghd/stage5_llava_margin

# Stage 4 repair / Stage 5 severity-margin training
# STAGE4_BACKEND=llava
# STAGE4_OUTPUT_DIR=output/fghd/stage4
# STAGE4_MAX_NEW_TOKENS=128
# DPO_LOSS_TYPE=severity_margin
# SEVERITY_MARGIN_SCALE=0.5
# SEVERITY_SCORE_NORMALIZER=3.0

# Optional Python override for bootstrap on unusual templates
# PYTHON_BIN=python3
